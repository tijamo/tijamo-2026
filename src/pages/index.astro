  .footer-left p { font-size: 0.82rem; color: var(--muted-light); }
  .footer-links, .footer-social { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .footer-links a, .footer-social a { font-size: 0.88rem; color: var(--muted-light); transition: color 0.2s; }
