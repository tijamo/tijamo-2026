---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <!-- A11y: skip link -->
  <a href="#main" class="skip-link">Skip to content</a>

  <!-- NAV -->
  <nav>
    <div class="container nav-inner">
      <a href="/" class="logo" aria-label="Tijamo home"><img src="/logo.svg" alt="Tijamo" height="34" /></a>

      <button type="button" class="theme-toggle" aria-label="Switch to dark theme" aria-pressed="false">
        <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>

      <button type="button" class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
        <span></span><span></span><span></span>
      </button>

      <ul class="nav-list" id="primary-nav">
        <li><a href="#about">About</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#cases">Case studies</a></li>
        <li><a href="#testimonials">Words</a></li>
        <li><a href="#contact" class="btn-nav">Say hello</a></li>
      </ul>
    </div>
  </nav>

  <main id="main">
    <!-- HERO -->
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">UX Leadership · Digital Optimisation · Design Systems</p>
          <h1>Hi, I'm Tim.<br/>I help enterprise teams ship&nbsp;usable products at&nbsp;scale.</h1>
          <p class="sub">25 years building digital products for finance, manufacturing and life sciences. Currently leading design on large-scale SaaS for world-class brands.</p>
          <div class="hero-cta">
            <a href="#contact" class="btn-primary">Say hello</a>
            <a href="/cv.pdf" class="link-cv" aria-label="Download CV (PDF)">
              <span aria-hidden="true">↓</span> Download CV
            </a>
          </div>
          <div class="hero-stat">
            <span class="stat-num">25</span>
            <span class="stat-label">years across UX, ecommerce and design&nbsp;leadership</span>
          </div>
        </div>

        <div class="hero-portrait">
          <img src="/tim.jpg" alt="Tim Moore" class="portrait" width="320" height="320" loading="eager" />
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="about" id="about">
      <div class="container about-grid">
        <p class="section-label">About</p>
        <div>
          <h2>A senior design leader who builds teams and ships product.</h2>
          <p>I've spent 25 years across agency and in-house, leading UX teams that ship at enterprise scale — from premium bespoke interfaces for global brands to ecommerce platforms doing serious volume. My focus today: DesignOps, hiring frameworks, and the rituals that make design teams reliably ship.</p>
          <p class="about-meta"><strong>Currently:</strong> design leadership in SaaS. <strong>Previously:</strong> agency and in-house roles spanning finance, manufacturing, life&nbsp;sciences, and travel.</p>
        </div>
      </div>
    </section>

    <!-- CLIENTS -->
    <section class="clients-strip">
      <div class="container">
        <p class="strip-label">Selected clients I've worked with</p>
        <!-- TODO: replace text with brand SVG logos in public/clients/ for richer presentation -->
        <div class="clients">
          <img src="/clients/who.svg" alt="World Health Organization" class="client-logo" />
          <img src="/clients/nasa.svg" alt="NASA" class="client-logo" />
          <img src="/clients/nhs.svg" alt="NHS" class="client-logo" />
          <img src="/clients/ideagen.svg" alt="Ideagen" class="client-logo client-logo-light" />
          <img src="/clients/ideagen-dark.svg" alt="" class="client-logo client-logo-dark" aria-hidden="true" />
          <img src="/clients/flybmi.svg" alt="flybmi" class="client-logo" />
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="services" id="services">
      <div class="container">
        <p class="section-label">What I do</p>
        <h2>Three areas where I make the&nbsp;difference</h2>

        <div class="service-grid">
          <div class="service-card" id="ux">
            <div class="service-num">01</div>
            <h3>User Experience</h3>
            <p>From research to ship. I've led the design of premium, bespoke interfaces used by some of the world's largest brands — usable, accessible, and engineered to scale.</p>
            <a href="#cases" class="service-link">See UX case studies <span aria-hidden="true">→</span></a>
          </div>

          <div class="service-card" id="digital">
            <div class="service-num">02</div>
            <h3>Digital Optimisation</h3>
            <p>20 years optimising ecommerce — from audiophiles to airlines. I help brands grow customer bases through measured, iterative improvement of the digital funnel.</p>
            <a href="#cases" class="service-link">See optimisation work <span aria-hidden="true">→</span></a>
          </div>

          <div class="service-card" id="leadership">
            <div class="service-num">03</div>
            <h3>Design Leadership</h3>
            <p>Scaling design at enterprise level: DesignOps, hiring frameworks, mentoring, and the team rituals that turn promising designers into senior contributors who ship.</p>
            <a href="#cases" class="service-link">How I lead <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- PULL QUOTE divider -->
    <section class="pullquote">
      <div class="container">
        <blockquote class="pq">
          <p>"Design leadership isn't about taste — it's about reliably shipping outcomes the business can measure."</p>
        </blockquote>
      </div>
    </section>

    <!-- CASE STUDIES -->
    <section class="cases" id="cases">
      <div class="container">
        <p class="section-label">Selected work</p>
        <h2>Case studies</h2>
        <p class="cases-intro">A short selection. Happy to talk through any of these in detail — and to share work that's under NDA.</p>

        <!-- TODO: replace placeholder copy below with real outcomes and numbers -->
        <div class="case-grid">
          <article class="case-card">
            <img src="/clients/ideagen.svg" alt="Ideagen" class="case-logo logo-light" height="36" />
            <img src="/clients/ideagen-dark.svg" alt="" class="case-logo logo-dark" height="36" aria-hidden="true" />
            <div class="case-meta">
              <span class="case-tag">Design Systems · SaaS</span>
              <span class="case-year">2022</span>
            </div>
            <h3>Ideagen — Helix design system</h3>
            <p class="case-result">Created Helix — Ideagen's human-first design system — to unify the user experience across the GRC SaaS portfolio. Built the foundations from principles and tokens through accessible components, content guidelines and a governance model that lets product teams adopt and contribute. Spans web and mobile, with a roadmap into voice and AR.</p>
            <p class="case-role">Role: Head of UX &amp; Design, partnering with engineering, product and brand.</p>
          </article>

          <article class="case-card">
            <img src="/clients/flybmi.svg" alt="flybmi" class="case-logo" height="36" />
            <div class="case-meta">
              <span class="case-tag">UX · Aviation</span>
              <span class="case-year">2018</span>
            </div>
            <h3>flybmi — booking platform redesign</h3>
            <p class="case-result">Modernised the booking experience for the British regional airline: a hero flight-search front door, a flexible promotions module to surface seasonal European routes from Bristol, East Midlands and beyond, and a fully responsive site across desktop and mobile.</p>
            <p class="case-role">Role: lead UX and design, with the airline's in-house digital team. flybmi ceased trading in Feb 2019.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials" id="testimonials">
      <div class="container">
        <p class="section-label">Kind words</p>
        <h2>What people say</h2>

        <div class="testimonial-grid">
          <figure class="t-card">
            <p class="t-theme">On craft</p>
            <div class="t-person">
              <span class="avatar" aria-hidden="true">AP</span>
              <div>
                <strong>Antony Price</strong>
                <span>CEO, Fly Arna (formerly Agoda)</span>
              </div>
            </div>
            <blockquote>"Tim is a pleasure to work with. Smart, insightful, great eye for detail and one of those guys that really rolls up their sleeves and just gets things done."</blockquote>
          </figure>

          <figure class="t-card">
            <p class="t-theme">On mentorship</p>
            <div class="t-person">
              <span class="avatar" aria-hidden="true">CP</span>
              <div>
                <strong>Corin Pye</strong>
                <span>Product Designer, Purplebricks</span>
              </div>
            </div>
            <blockquote>"Tim opened the door for me into the design world. He cares as much about the success of his team as he cares about the success of a project."</blockquote>
          </figure>

          <figure class="t-card">
            <p class="t-theme">On leadership</p>
            <div class="t-person">
              <span class="avatar" aria-hidden="true">MR</span>
              <div>
                <strong>Molly Rice UXC</strong>
                <span>Senior UI/UX Designer, Remote New Media</span>
              </div>
            </div>
            <blockquote>"Tim took me on as an apprentice and supported my growth into an experienced UX designer. His inclusivity and accessibility-focused approach is something every business needs."</blockquote>
          </figure>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="contact" id="contact">
      <div class="container">
        <p class="section-label">Get in touch</p>
        <h2>Let's say hello.</h2>
        <p class="contact-sub">The fastest way to reach me is one of these:</p>

        <ul class="contact-quick">
          <!-- TODO: confirm calendar URL, then update href -->
          <li><a href="https://linkedin.com/in/tijamo" target="_blank" rel="noopener"><span aria-hidden="true">in</span> LinkedIn</a></li>
          <li><a href="https://cal.com/tijamo" target="_blank" rel="noopener"><span aria-hidden="true">⏱</span> Book a 20-min chat</a></li>
        </ul>

        <p class="contact-or">Or drop a message:</p>

        <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hp-field" aria-hidden="true"><label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn-primary">Send message</button>
          <p class="form-fineprint">Your details are only used to reply. No newsletter, no sharing.</p>
        </form>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-left">
        <a href="/" class="logo" aria-label="Tijamo home"><img src="/logo.svg" alt="Tijamo" height="28" class="logo-footer" /></a>
        <p>© {new Date().getFullYear()} Tijamo. All rights reserved.</p>
      </div>
      <div class="footer-links">
        <a href="#about">About</a>
        <a href="#cases">Case studies</a>
        <a href="#contact">Say hello</a>
        <a href="/cv.pdf">CV</a>
      </div>
      <div class="footer-social">
        <a href="https://linkedin.com/in/tijamo" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://twitter.com/tijamodesign" target="_blank" rel="noopener">Twitter</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Skip link */
  .skip-link {
    position: absolute; left: -9999px; top: 0;
    background: var(--surface-dark); color: var(--on-dark);
    padding: 0.75rem 1.25rem; z-index: 999;
    font-size: 0.88rem; border-radius: 0 0 6px 0;
  }
  .skip-link:focus { left: 0; }

  /* Global focus-visible */
  :global(a:focus-visible),
  :global(button:focus-visible),
  :global(input:focus-visible),
  :global(textarea:focus-visible) {
    outline: 2px solid var(--red);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: color-mix(in srgb, var(--white) 96%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1rem; padding-bottom: 1rem;
  }
  .logo { display: flex; align-items: center; }
  .nav-list { list-style: none; display: flex; gap: 2rem; align-items: center; }
  .nav-list a { font-size: 0.88rem; color: var(--black); transition: color 0.2s; font-weight: 400; background: transparent; }
  .nav-list a:hover { color: var(--red); }
  .btn-nav {
    background: var(--red); color: var(--on-dark) !important;
    padding: 0.5rem 1.2rem; border-radius: 2rem;
    font-size: 0.85rem !important; font-weight: 500 !important; transition: background 0.2s !important;
  }
  .btn-nav:hover { background: var(--red-dark) !important; }

  /* Theme toggle */
  .theme-toggle {
    margin-left: auto; margin-right: 0.75rem;
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    background: transparent; border: 1px solid var(--border);
    color: var(--black); cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .theme-toggle:hover { border-color: var(--red); color: var(--red); }
  .theme-toggle .icon-moon { display: none; }
  [data-theme="dark"] .theme-toggle .icon-sun { display: none; }
  [data-theme="dark"] .theme-toggle .icon-moon { display: block; }

  /* Mobile nav burger button */
  .nav-burger {
    display: none; cursor: pointer; width: 44px; height: 44px; position: relative;
    background: transparent; border: 0; padding: 0;
  }
  .nav-burger span {
    position: absolute; left: 8px; right: 8px; height: 2px; background: currentColor;
    transition: transform 0.25s ease, opacity 0.25s ease, top 0.25s ease;
  }
  .nav-burger span:nth-child(1) { top: 14px; }
  .nav-burger span:nth-child(2) { top: 21px; }
  .nav-burger span:nth-child(3) { top: 28px; }
  .nav-burger[aria-expanded="true"] span:nth-child(1) { top: 21px; transform: rotate(45deg); }
  .nav-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-burger[aria-expanded="true"] span:nth-child(3) { top: 21px; transform: rotate(-45deg); }

  /* HERO */
  .hero { padding: 6rem 0 5rem; background: var(--bg-light); }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem; align-items: center;
  }
  .eyebrow {
    font-size: 0.78rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--red); font-weight: 500; margin-bottom: 1.5rem;
  }
  .hero h1 { font-size: clamp(2.3rem, 4.5vw, 3.8rem); margin-bottom: 1.5rem; color: var(--black); }
  .sub { font-size: 1.1rem; color: var(--muted); max-width: 540px; margin-bottom: 2rem; line-height: 1.7; }
  .hero-cta { display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center; margin-bottom: 2.5rem; }
  .btn-primary {
    background: var(--red); color: var(--on-dark);
    padding: 0.85rem 2rem; border-radius: 2rem;
    font-size: 0.88rem; font-weight: 700; transition: background 0.25s;
    border: none; cursor: pointer; display: inline-block;
  }
  .btn-primary:hover { background: var(--red-dark); }
  .link-cv {
    color: var(--black); font-size: 0.9rem; font-weight: 500;
    border-bottom: 1.5px solid var(--border); padding-bottom: 2px; transition: border-color 0.2s;
  }
  .link-cv:hover { border-color: var(--red); color: var(--red); }
  .hero-stat { display: flex; align-items: baseline; gap: 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border); max-width: 460px; }
  .stat-num { font-family: 'IBM Plex Serif', Georgia, serif; font-size: 3rem; line-height: 1; color: var(--red); }
  .stat-label { font-size: 0.85rem; color: var(--muted); }

  .hero-portrait { display: flex; justify-content: center; }
  .portrait {
    width: 320px; height: 320px; border-radius: 50%;
    object-fit: cover; object-position: center top;
    box-shadow: 0 12px 32px var(--shadow);
    border: 4px solid var(--surface);
  }
  [data-theme="dark"] .portrait { border-color: var(--surface); }

  /* ABOUT */
  .about { padding: 6rem 0; }
  .about-grid {
    display: grid; grid-template-columns: 200px 1fr; gap: 3rem; align-items: start;
  }
  .about-grid h2 { font-size: clamp(1.8rem, 3vw, 2.3rem); color: var(--black); margin-bottom: 1.25rem; }
  .about-grid p { color: var(--muted); line-height: 1.75; margin-bottom: 1rem; max-width: 680px; }
  .about-meta { font-size: 0.95rem; }
  .about-meta strong { color: var(--black); font-weight: 500; }

  /* CLIENTS STRIP */
  .clients-strip { padding: 2.5rem 0; background: var(--bg-light); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .strip-label { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.25rem; }
  .clients { display: flex; gap: 3rem; flex-wrap: wrap; align-items: center; }
  .clients span { font-size: 0.95rem; letter-spacing: 0.05em; color: var(--dark); text-transform: uppercase; font-weight: 600; }
  .client-logo { height: 28px; width: auto; display: block; opacity: 0.85; transition: opacity 0.2s; }
  .client-logo:hover { opacity: 1; }
  [data-theme="dark"] .client-logo { filter: brightness(1.15); }
  .client-logo-dark { display: none; }
  [data-theme="dark"] .client-logo-light { display: none; }
  [data-theme="dark"] .client-logo-dark { display: block; filter: none; }

  /* SECTION LABELS */
  .section-label {
    font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--red); font-weight: 500; margin-bottom: 0.75rem;
  }

  /* SERVICES */
  .services { padding: 7rem 0; }
  .services h2 { font-size: clamp(2rem, 4vw, 2.8rem); margin-bottom: 4rem; color: var(--black); max-width: 760px; }
  .service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .service-card {
    border: 1px solid var(--border); border-radius: 6px;
    padding: 2.5rem; transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    background: var(--surface);
  }
  .service-card:hover { transform: translateY(-5px); box-shadow: 0 8px 28px var(--shadow); border-color: var(--red); }
  .service-num { font-family: 'IBM Plex Serif', Georgia, serif; font-size: 0.85rem; color: var(--red); font-weight: 700; margin-bottom: 1.25rem; letter-spacing: 0.1em; }
  .service-card h3 { font-size: 1.44rem; margin-bottom: 1rem; color: var(--black); }
  .service-card p { color: var(--muted); font-size: 0.95rem; margin-bottom: 1.5rem; line-height: 1.7; }
  .service-link { font-size: 0.85rem; font-weight: 600; color: var(--red); }
  .service-link:hover { text-decoration: underline; }

  /* PULL QUOTE */
  .pullquote { padding: 5rem 0; background: var(--surface-dark); color: var(--on-dark); }
  .pq { max-width: 880px; }
  .pq p {
    font-family: 'IBM Plex Serif', Georgia, serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem); line-height: 1.4; color: var(--on-dark);
    font-style: italic; position: relative; padding-left: 2rem;
    border-left: 3px solid var(--red);
  }

  /* CASE STUDIES */
  .cases { padding: 7rem 0; background: var(--bg-light); }
  .cases h2 { font-size: clamp(2rem, 4vw, 2.8rem); margin-bottom: 1rem; color: var(--black); }
  .cases-intro { color: var(--muted); max-width: 600px; margin-bottom: 3.5rem; line-height: 1.7; }
  .case-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .case-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
    padding: 2rem; transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .case-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px var(--shadow); }
  .case-logo { height: 36px; width: auto; margin-bottom: 1.25rem; display: block; }
  [data-theme="dark"] .case-logo { filter: brightness(1.15); }
  .case-logo.logo-dark { display: none; }
  [data-theme="dark"] .case-logo.logo-light { display: none; }
  [data-theme="dark"] .case-logo.logo-dark { display: block; filter: none; }
  .case-result a { color: var(--red); border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .case-result a:hover { color: var(--red-dark); }
  .case-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
  .case-tag { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); font-weight: 600; }
  .case-year { font-size: 0.75rem; color: var(--muted); }
  .case-card h3 { font-size: 1.25rem; margin-bottom: 1rem; color: var(--black); line-height: 1.3; }
  .case-result { color: var(--black); font-size: 0.95rem; line-height: 1.6; margin-bottom: 1rem; }
  .case-role { color: var(--muted); font-size: 0.82rem; font-style: italic; }

  /* TESTIMONIALS */
  .testimonials { padding: 7rem 0; }
  .testimonials h2 { font-size: clamp(2rem, 3.5vw, 2.5rem); margin-bottom: 3.5rem; color: var(--black); }
  .testimonial-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .t-card {
    background: var(--bg-light); border: 1px solid var(--border); border-radius: 6px;
    padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem;
  }
  .t-theme { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); font-weight: 600; }
  .t-person { display: flex; align-items: center; gap: 1rem; }
  .avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--dark); color: var(--on-dark);
    display: flex; align-items: center; justify-content: center;
    font-weight: 600; font-size: 0.85rem; letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .t-person strong { display: block; font-size: 0.92rem; color: var(--black); font-weight: 600; }
  .t-person span { font-size: 0.78rem; color: var(--muted); }
  .t-card blockquote { font-size: 0.92rem; color: var(--muted); line-height: 1.75; font-style: italic; }

  /* CONTACT */
  .contact { padding: 7rem 0; background: var(--bg-light); }
  .contact h2 { font-size: clamp(2rem, 4vw, 2.8rem); margin-bottom: 1rem; color: var(--black); }
  .contact-sub { color: var(--muted); margin-bottom: 1.5rem; }
  .contact-quick { list-style: none; display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }
  .contact-quick a {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.25rem; background: var(--surface);
    border: 1px solid var(--border); border-radius: 2rem;
    font-size: 0.88rem; color: var(--black); font-weight: 500;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .contact-quick a:hover { border-color: var(--red); color: var(--red); transform: translateY(-2px); }
  .contact-quick a span { color: var(--red); font-weight: 700; }
  .contact-or { color: var(--muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .contact-form { max-width: 640px; display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-size: 0.85rem; font-weight: 500; color: var(--black); }
  input, textarea {
    border: 1px solid var(--border); border-radius: 6px;
    padding: 0.7rem 1rem; font-size: 0.95rem; font-family: inherit;
    background: var(--surface); transition: border-color 0.2s;
    color: var(--black);
  }
  input:focus, textarea:focus { outline: none; border-color: var(--red); }
  textarea { resize: vertical; }
  .form-fineprint { font-size: 0.78rem; color: var(--muted); margin-top: 0.5rem; }
  .hp-field { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

  /* FOOTER */
  footer { background: var(--surface-dark); color: var(--on-dark); padding: 3rem 0; }
  .footer-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .footer-left { display: flex; flex-direction: column; gap: 0.75rem; }
