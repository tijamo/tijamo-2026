  /* Visible focus on the burger */
  .nav-burger:focus-visible {
    outline: 2px solid var(--red);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
    .service-card:hover, .case-card:hover, .contact-quick a:hover {
      transform: none;
    }
  }
</style>

<script>
  // Theme toggle
  const themeBtn = document.querySelector('.theme-toggle') as HTMLButtonElement | null;
  const syncThemeBtn = () => {
    if (!themeBtn) return;
    const dark = document.documentElement.getAttribute('data-theme') === 'dark';
    themeBtn.setAttribute('aria-pressed', String(dark));
    themeBtn.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
  };
  syncThemeBtn();
  themeBtn?.addEventListener('click', () => {
    const dark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (dark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
    syncThemeBtn();
  });
  // Follow OS changes when user hasn't explicitly chosen
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      if (e.matches) document.documentElement.setAttribute('data-theme', 'dark');
      else document.documentElement.removeAttribute('data-theme');
      syncThemeBtn();
    }
  });

  const burger = document.querySelector('.nav-burger');
  const navList = document.getElementById('primary-nav');
  if (burger && navList) {
    const setOpen = (open: boolean) => {
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      navList.setAttribute('data-open', String(open));
    };
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });
    // Close when a nav link is tapped
    navList.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setOpen(false)));
    // Close on Escape for keyboard users
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        (burger as HTMLButtonElement).focus();
      }
    });
  }
</script>
