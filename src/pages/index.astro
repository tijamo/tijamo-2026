  /* MOBILE */
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-portrait { order: -1; }
    .portrait { width: 200px; height: 200px; }
    .about-grid { grid-template-columns: 1fr; gap: 1rem; }
