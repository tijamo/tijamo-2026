      margin: 1rem 2rem; text-align: center; border-radius: 2rem;
    }
    .form-row { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
    .hero-stat { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
